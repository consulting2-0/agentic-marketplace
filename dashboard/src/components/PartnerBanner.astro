---
// Consulting 2.0 brand banner
---

<section class="px-6 pt-4 pb-1">
  <a
    href="https://consulting20.com"
    target="_blank"
    rel="noopener noreferrer"
    class="group relative flex items-center gap-3 overflow-hidden rounded-lg border border-border bg-surface-1 px-4 py-3 transition-all hover:border-border-hover"
  >
    <!-- Gradient glow background -->
    <div class="absolute inset-0 pointer-events-none"
      style="background: linear-gradient(90deg, rgba(0,87,255,0.07) 0%, rgba(0,229,153,0.04) 50%, transparent 100%);">
    </div>

    <!-- C20 hexagon icon -->
    <div class="relative shrink-0 w-8 h-8 rounded-md overflow-hidden" style="background: #040D20; border: 1px solid rgba(0,87,255,0.3);">
      <svg width="32" height="32" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(16, 16) scale(1.9)">
          <path d="M44 4L80 24V64L44 84L8 64V24L44 4Z" fill="#040D20" stroke="#0057FF" stroke-width="1.5"/>
          <line x1="44" y1="24" x2="26" y2="46" stroke="#0057FF" stroke-opacity="0.5" stroke-width="1.3"/>
          <line x1="44" y1="24" x2="62" y2="46" stroke="#0057FF" stroke-opacity="0.5" stroke-width="1.3"/>
          <line x1="26" y1="46" x2="44" y2="64" stroke="#00E599" stroke-opacity="0.65" stroke-width="1.3"/>
          <line x1="62" y1="46" x2="44" y2="64" stroke="#00E599" stroke-opacity="0.65" stroke-width="1.3"/>
          <circle cx="44" cy="24" r="5.5" fill="#0057FF"/>
          <circle cx="26" cy="46" r="4.5" fill="#3D80FF"/>
          <circle cx="62" cy="46" r="4.5" fill="#3D80FF"/>
          <circle cx="44" cy="64" r="5.5" fill="#00E599"/>
        </g>
      </svg>
    </div>

    <!-- Content -->
    <div class="relative flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-[13px] font-semibold" style="font-family: 'Syne', sans-serif; color: #E4EBF8;">Consulting</span>
        <span class="text-[13px] font-bold" style="font-family: 'Syne', sans-serif; color: #00E599;">2.0</span>
        <span class="rounded px-1.5 py-px text-[9px] font-semibold uppercase tracking-wider"
          style="background: rgba(0,87,255,0.12); color: #4d81ff; border: 1px solid rgba(0,87,255,0.2);">
          Open Source
        </span>
      </div>
      <p class="text-[11px] text-text-tertiary mt-0.5 truncate sm:whitespace-normal">
        The best open source agentic marketplace for enterprise intelligence.
      </p>
    </div>

    <!-- Right badges -->
    <div class="relative hidden sm:flex items-center gap-2 shrink-0">
      <div class="flex items-center gap-1 rounded px-2 py-1"
        style="background: rgba(0,229,153,0.07); border: 1px solid rgba(0,229,153,0.15);">
        <svg width="8" height="8" viewBox="0 0 10 10" fill="#00E599">
          <circle cx="5" cy="5" r="5"/>
        </svg>
        <span class="text-[10px] font-medium" style="color: #00E599;">consulting20.com</span>
      </div>
    </div>

    <!-- Arrow -->
    <svg class="relative w-3.5 h-3.5 text-text-tertiary opacity-0 group-hover:opacity-100 transition-opacity shrink-0"
      fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</section>
