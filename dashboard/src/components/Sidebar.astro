---
import NavItem from './NavItem.astro';
import { TYPE_CONFIG, ICONS } from '../lib/icons';
import AuthButton from './AuthButton';
import MyComponentsSidebarItem from './MyComponentsSidebarItem';

const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<div class="flex flex-col h-full">
  <!-- Logo -->
  <div class="px-4 py-4 border-b border-border">
    <a href="/" class="flex items-center gap-2.5">
      <!-- Consulting 2.0 hexagon icon mark -->
      <svg width="26" height="26" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
        <rect width="200" height="200" rx="40" fill="#071535"/>
        <g transform="translate(16, 16) scale(1.9)">
          <path d="M44 4L80 24V64L44 84L8 64V24L44 4Z" fill="#071535" stroke="#0057FF" stroke-width="1.5"/>
          <line x1="44" y1="24" x2="26" y2="46" stroke="#0057FF" stroke-opacity="0.5" stroke-width="1.3"/>
          <line x1="44" y1="24" x2="62" y2="46" stroke="#0057FF" stroke-opacity="0.5" stroke-width="1.3"/>
          <line x1="26" y1="46" x2="44" y2="64" stroke="#00E599" stroke-opacity="0.65" stroke-width="1.3"/>
          <line x1="62" y1="46" x2="44" y2="64" stroke="#00E599" stroke-opacity="0.65" stroke-width="1.3"/>
          <line x1="26" y1="46" x2="62" y2="46" stroke="#7B4FFF" stroke-opacity="0.35" stroke-width="1"/>
          <circle cx="44" cy="24" r="5.5" fill="#0057FF"/>
          <circle cx="44" cy="24" r="9" fill="#0057FF" fill-opacity="0.15"/>
          <circle cx="26" cy="46" r="4.5" fill="#3D80FF"/>
          <circle cx="62" cy="46" r="4.5" fill="#3D80FF"/>
          <circle cx="44" cy="64" r="5.5" fill="#00E599"/>
          <circle cx="44" cy="64" r="9" fill="#00E599" fill-opacity="0.15"/>
          <circle cx="20" cy="32" r="2.8" fill="#7B4FFF" fill-opacity="0.8"/>
          <circle cx="68" cy="32" r="2.8" fill="#7B4FFF" fill-opacity="0.8"/>
          <circle cx="20" cy="58" r="2.2" fill="#FF8C00" fill-opacity="0.7"/>
          <circle cx="68" cy="58" r="2.2" fill="#FF8C00" fill-opacity="0.7"/>
        </g>
      </svg>
      <div class="flex flex-col">
        <span class="text-[13px] font-semibold tracking-tight leading-none" style="font-family: 'Syne', sans-serif;">
          <span class="text-text-primary">Consulting </span><span style="color: #00E599;">2.0</span>
        </span>
        <span class="text-[9px] tracking-widest leading-none mt-0.5 uppercase" style="color: #8A9BBE; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.15em;">Agentic Marketplace</span>
      </div>
      <span class="ml-auto text-[9px] font-semibold uppercase tracking-wider bg-primary-500/15 text-primary-400 px-1.5 py-0.5 rounded">Beta</span>
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto px-2 py-1 space-y-0.5">
    <!-- Workplace section -->
    <div class="px-2 py-2">
      <span class="text-[11px] font-medium text-text-tertiary uppercase tracking-widest">My Workspace</span>
    </div>

    <!-- My Components (React island) -->
    <MyComponentsSidebarItem client:load isActive={isActive('/my-components')} />

    <!-- Divider -->
    <div class="my-3 mx-2 border-t border-border"></div>

    <!-- Browse section -->
    <div class="px-2 py-2">
      <span class="text-[11px] font-medium text-text-tertiary uppercase tracking-widest">Catalog</span>
    </div>

    {Object.entries(TYPE_CONFIG).map(([type, config]) => (
      <a
        href={`/${type}`}
        data-nav-type={type}
        class:list={[
          'sidebar-nav-link flex items-center gap-2.5 px-2.5 py-[6px] rounded-md text-[13px] transition-colors group',
          isActive(`/${type}`)
            ? 'bg-surface-3 text-text-primary font-medium'
            : 'text-text-secondary hover:text-text-primary hover:bg-surface-2',
        ]}
      >
        <span
          class:list={[
            'sidebar-nav-icon w-4 h-4 shrink-0 [&>svg]:w-4 [&>svg]:h-4',
            isActive(`/${type}`) ? 'text-text-primary' : 'text-text-tertiary group-hover:text-text-secondary',
          ]}
          set:html={ICONS[type]}
        />
        <span class="truncate">{config.label}</span>
        <span class="sidebar-nav-count ml-auto text-[11px] tabular-nums text-text-tertiary" data-count-type={type}></span>
      </a>
    ))}

  </nav>

  <!-- Bottom -->
  <div class="px-2 py-3 border-t border-border">
    <AuthButton client:load />
  </div>
</div>

<script>
  function updateSidebarActive() {
    const path = window.location.pathname.replace(/^\//, '').split('/')[0] || 'skills';
    document.querySelectorAll('.sidebar-nav-link').forEach((link) => {
      const type = (link as HTMLElement).dataset.navType;
      const icon = link.querySelector('.sidebar-nav-icon');
      if (type === path) {
        link.classList.remove('text-text-secondary', 'hover:text-text-primary', 'hover:bg-surface-2');
        link.classList.add('bg-surface-3', 'text-text-primary', 'font-medium');
        icon?.classList.remove('text-text-tertiary', 'group-hover:text-text-secondary');
        icon?.classList.add('text-text-primary');
      } else {
        link.classList.remove('bg-surface-3', 'text-text-primary', 'font-medium');
        link.classList.add('text-text-secondary', 'hover:text-text-primary', 'hover:bg-surface-2');
        icon?.classList.remove('text-text-primary');
        icon?.classList.add('text-text-tertiary', 'group-hover:text-text-secondary');
      }
    });
  }

  // Patch pushState to emit events for sidebar sync
  const origPushState = history.pushState.bind(history);
  history.pushState = function(...args: Parameters<typeof origPushState>) {
    origPushState(...args);
    updateSidebarActive();
  };

  window.addEventListener('popstate', updateSidebarActive);

  // Listen for component counts from React grid
  window.addEventListener('component-counts', ((e: CustomEvent) => {
    const counts = e.detail as Record<string, number>;
    document.querySelectorAll('.sidebar-nav-count').forEach((el) => {
      const type = (el as HTMLElement).dataset.countType;
      if (type && counts[type]) {
        el.textContent = String(counts[type]);
      }
    });
  }) as EventListener);
</script>
